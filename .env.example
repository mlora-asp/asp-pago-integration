# Copiar como .env local y reemplazar con valores reales del ambiente.
# NUNCA subir el .env real a Git.

SPRING_PROFILES_ACTIVE=dev

# Puerto local del bridge. Por defecto 8095 para compatibilidad con el Kong
# local configurado en ../asp-pago-kong/kong.yml.
APP_PORT=8095

# Seguridad de ingreso Kong -> asp-pago-integration
GATEWAY_SHARED_SECRET=REEMPLAZAR_EN_AMBIENTE
GATEWAY_ALLOWED_CLIENT_IDS=asp-pagos-auth-service

# Cifrado de payload ASP Pago
SECURITY_CRYPTO_ENABLED=true
CRYPTO_SECRET=REEMPLAZAR_EN_AMBIENTE

# Caudex
CAUDEX_BASE_URL=REEMPLAZAR_EN_AMBIENTE
CAUDEX_CLIENT_ID=REEMPLAZAR_EN_AMBIENTE
CAUDEX_CLIENT_SECRET=REEMPLAZAR_EN_AMBIENTE
CAUDEX_SCOPE=message.read

# Contrato ASP Pago
ASP_PAGO_SUCCESS_CODE=9999
ASP_PAGO_DEFAULT_CURRENCY=MXN
ASP_PAGO_DEFAULT_CHANNEL=API
ASP_PAGO_ONBOARDING_REFERENCE_PREFIX=ONBOARDING-
ASP_PAGO_DEFAULT_CHANNEL_CODE=1
ASP_PAGO_DEFAULT_INSTRUMENT_CODE=1
ASP_PAGO_DEFAULT_ACCOUNT_TYPE_CODE=1
