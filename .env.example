# Copiar como .env y reemplazar con valores del ambiente.
# NUNCA subir el .env real a Git.

SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080

# Seguridad de ingreso Kong -> asp-pago-integration
GATEWAY_SHARED_SECRET=REEMPLAZAR_EN_AMBIENTE

# Cifrado de payload ASP Pago
SECURITY_CRYPTO_ENABLED=true
CRYPTO_SECRET=REEMPLAZAR_EN_AMBIENTE

# Caudex
CAUDEX_BASE_URL=REEMPLAZAR_EN_AMBIENTE
CAUDEX_CLIENT_ID=REEMPLAZAR_EN_AMBIENTE
CAUDEX_CLIENT_SECRET=REEMPLAZAR_EN_AMBIENTE
